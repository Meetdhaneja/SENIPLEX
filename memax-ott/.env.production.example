# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=MEMAX OTT
ENVIRONMENT=production
DEBUG=False

# ─── Security (CHANGE THESE IN PRODUCTION!) ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_python_secrets_token_hex_32_chars

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=memax_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=memax_db
DATABASE_URL=postgresql://memax_user:CHANGE_ME_strong_db_password@postgres:5432/memax_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Replace with your actual domain after deploying (e.g. https://api.memax.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Replace with your domain: https://www.memax.com
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Admin Defaults ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@memax.com
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_USERNAME=admin

# ─── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
