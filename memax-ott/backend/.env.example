# MEMAX OTT Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# 
# Replace these values with your PostgreSQL credentials:
# - USERNAME: Your PostgreSQL username (default: postgres)
# - PASSWORD: Your PostgreSQL password
# - HOST: Database host (default: localhost)
# - PORT: PostgreSQL port (default: 5432)
# - DATABASE_NAME: Your database name (e.g., memax_db)

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/memax_db

# Enable SQL query logging (set to True for debugging)
DB_ECHO=False

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=MEMAX OTT
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ============================================
# SECURITY
# ============================================
# IMPORTANT: Change this to a strong random string in production!
# Must be at least 32 characters long
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars-long-please

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ADMIN CREDENTIALS
# ============================================
# Default admin user credentials
# CHANGE THESE IN PRODUCTION!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@memax.com

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# AI/ML CONFIGURATION
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=app/ai/faiss/index_store/memax_movie.index
RECOMMENDATION_LIMIT=20
SIMILARITY_THRESHOLD=0.5

# ============================================
# CORS ORIGINS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
